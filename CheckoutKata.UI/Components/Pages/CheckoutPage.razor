@page "/checkout"
@inherits BasePageClass

<PageTitle>Checkout</PageTitle>

<div @ref="focusTarget"
     tabindex="0"
     @onkeydown="HandleKey"
     @onkeydown:preventDefault="true">


    <MudText Typo="Typo.h3">Checkout</MudText>

    <CheckoutCardsComponent Skus="@SkuCatalogue.Skus" OnScan="@Scan" />

    <br />

    <MudPaper Class="pa-4 mt-4">
        <MudText Typo="Typo.h6">Items scanned</MudText>

        @if (Checkout.ScannedItems.Count == 0)
        {
            <MudText Color="Color.Secondary">No items yet</MudText>
        }
        else
        {
            <MudList T="string" Dense="true">
                @foreach (var kvp in GroupedItems)
                {
                    <MudListItem>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                            <MudText>@($"{kvp.Key} × {kvp.Value}")</MudText>

                            <MudTooltip Text="Remove one">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Color="Color.Secondary"
                                               OnClick="@(() => Decrement(kvp.Key))" />
                            </MudTooltip>

                            <MudTooltip Text="Add one">
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Color="Color.Primary"
                                               OnClick="@(() => Increment(kvp.Key))" />
                            </MudTooltip>

                        </MudStack>
                    </MudListItem>

                }
            </MudList>

        }

        <MudCollapse Expanded="Checkout.ScannedItems.Count > 0">
            <MudStack Row="true" Spacing="2" Class="mt-2">
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="RemoveLast">Remove last</MudButton>
                <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="ClearAll">Clear basket</MudButton>
            </MudStack>
        </MudCollapse>

    </MudPaper>

    <br/>

    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="ma-2 px-4 py-3" Style="font-size:1.2rem;">
        Total: £@Total
    </MudChip>

</div>