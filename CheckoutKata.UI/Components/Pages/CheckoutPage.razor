@page "/checkout"

<PageTitle>Checkout</PageTitle>

<MudText Typo="Typo.h3">Checkout</MudText>

<CheckoutCardsComponent Skus="@Skus" OnScan="@Scan" />

<br />

<MudPaper Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">Items scanned</MudText>

    @if (Checkout.ScannedItems.Count == 0)
    {
        <MudText Color="Color.Secondary">No items yet</MudText>
    }
    else
    {
        <MudList T="string" Dense="true">
            @foreach (var kvp in GroupedItems)
            {
                <MudListItem>
                    <MudText>@($"{kvp.Key} × {kvp.Value}")</MudText>
                </MudListItem>
            }
        </MudList>

    }

    <MudCollapse Expanded="Checkout.ScannedItems.Count > 0">
        <MudStack Row="true" Spacing="2" Class="mt-2">
            <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="RemoveLast">Remove last</MudButton>
            <MudButton Color="Color.Secondary" Variant="Variant.Outlined" OnClick="ClearAll">Clear basket</MudButton>
        </MudStack>
    </MudCollapse>

</MudPaper>

<br/>

<MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Class="ma-2 px-4 py-3" Style="font-size:1.2rem;">
    Total: £@Total
</MudChip>
