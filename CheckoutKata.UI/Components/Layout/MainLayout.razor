@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudPopoverProvider />
<MudSnackbarProvider />

<PageTitle>Checkout</PageTitle>

<CascadingValue Value="this">
    <MudLayout>
        <MudAppBar Style="background: linear-gradient(to bottom, #FF4F00 0%, #CC3F00 100%); color: white;" Elevation="4">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
            <MudText Typo="Typo.h5" Class="ml-3">Checkout</MudText>
            <MudSpacer />
        </MudAppBar>
        <MudDrawer Class="bright-sidebar" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
            <NavMenu />
        </MudDrawer>
        <MudMainContent>
            @Body
        </MudMainContent>
    </MudLayout>
</CascadingValue>